# YouTube Data API v3 — https://console.cloud.google.com/apis/credentials (primary + fallback)
YOUTUBE_API_KEY=your_primary_youtube_api_key
YOUTUBE_API_KEY_2=your_fallback_youtube_api_key

# Tavily Search API — https://tavily.com (primary + fallback account)
TAVILY_API_KEY=your_primary_tavily_api_key
TAVILY_API_KEY_2=your_fallback_tavily_api_key

# GitHub API — optional, increases rate limit (https://github.com/settings/tokens)
GITHUB_TOKEN=your_github_personal_access_token

# Optional: secret for manual refresh (POST /api/refresh) and Vercel Cron (GET /api/refresh)
REFRESH_SECRET=your_optional_refresh_secret
CRON_SECRET=your_vercel_cron_secret

# Cache TTL in seconds (default: 14400 = 4 hours)
CACHE_TTL_SECONDS=14400

# YouTube-only cache TTL (default: 86400 = 24 hours — skips YouTube API on refresh)
YOUTUBE_CACHE_TTL_SECONDS=86400